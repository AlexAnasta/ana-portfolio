---
import Skills from "@/components/Skills.astro";
import Contribution from "@/components/Contribution.astro";
import Communication from "@/components/Communication.astro";
import AboutMeCC from "../components/AboutMeCC.astro";
import ProfileActionButton from "../components/ProfileActionButton.astro";
import ProfileFacts from "../components/ProfileFacts.astro";
import ProfileInfo from "../components/ProfileInfo.astro";
import TabsButtons from "../components/TabsButtons.tsx";
import ResearchStatement from "../components/ResearchStatement.astro";
import Layout from "../layouts/Layout.astro";

const tabs = [
	{ value: "about", label: "About" },
	{ value: "contribution", label: "Contribution" },
	// { value: "communication", label: t("home.tabs.communication") },
	{ value: "skills", label: "Skills" },
] as const;
---

<Layout
	title="Anastasia Rusakovich | Portfolio"
	description="A simple portfolio created with Astro."
	scrollSmooth={false}
>
	<>
		<ProfileInfo />
		<ProfileFacts />
		<ProfileActionButton />
		<ResearchStatement />
		<TabsButtons client:idle tabs={tabs}>
			<AboutMeCC slot="about" />
			<Contribution slot="contribution" />
			<!-- <Communication slot="communication" /> -->
			<Skills slot="skills" />
		</TabsButtons>
	</>
</Layout>