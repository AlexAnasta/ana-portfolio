---
import type { Locale } from "@/i18n";
import { getLocalizedContent } from "@/i18n/content";
import type { CommunicationCategory, CommunicationEvent } from "@/i18n/content/types";
import { Badge } from "./ui/badge";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const { communications } = getLocalizedContent(locale);

type FeaturedResult = { item: CommunicationEvent; subgroupTitle?: string } | null;

function extractFeatured(category: CommunicationCategory): FeaturedResult {
  if (category.subgroups) {
    for (const group of category.subgroups) {
      const item = group.items.find((i) => i.featured);
      if (item) return { item, subgroupTitle: group.title };
    }
    return null;
  }
  const item = (category.items ?? []).find((i) => i.featured);
  return item ? { item } : null;
}

function withoutFeatured(category: CommunicationCategory): CommunicationCategory {
  if (category.subgroups) {
    return {
      ...category,
      subgroups: category.subgroups.map((g) => ({
        ...g,
        items: g.items.filter((i) => !i.featured),
      })),
    };
  }
  return { ...category, items: (category.items ?? []).filter((i) => !i.featured) };
}
---

<div class="flex flex-col gap-12 mt-10 px-4 w-full text-n200">
  {communications.map((category) => {
    const featured = extractFeatured(category);
    const rest = withoutFeatured(category);
    return (
      <section>
        <h2 class="text-3xl font-bold mb-6 text-center text-primary-dark">{category.title}</h2>
        <div class="flex rounded-xl border border-n700 bg-n800/60 overflow-hidden h-36 md:h-44">

          {/* Square photo */}
          {category.cover && (
            <div class="w-36 md:w-44 shrink-0 overflow-hidden">
              <img src={category.cover} alt={category.title} class="w-full h-full object-cover" loading="lazy" />
            </div>
          )}

          {/* Scrollable content */}
          <div class="flex-1 overflow-y-auto py-3 px-4 communication-scroll">

            {/* ── Featured item ── */}
            {featured && (
              <div>
                <div class="flex items-start gap-2 rounded-lg bg-teal-900/20 border-l-2 border-teal-400 pl-2 pr-1 py-1.5 mb-2">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 shrink-0 mt-0.5 text-teal-400" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z"/>
                  </svg>
                  <div class="flex flex-col gap-0.5 flex-1">
                    {featured.subgroupTitle && (
                      <span class="text-xs font-semibold uppercase tracking-widest text-teal-400 leading-none mb-0.5">{featured.subgroupTitle}</span>
                    )}
                    {(featured.item.date || featured.item.location) && (
                      <div class="flex flex-wrap items-center gap-2 mb-0.5">
                        {featured.item.date && (
                          <Badge className="bg-primary-dark w-fit rounded-md whitespace-nowrap text-xs">
                            {featured.item.date}
                          </Badge>
                        )}
                        {featured.item.location && (
                          <span class="flex items-center gap-1 text-xs font-medium text-teal-400">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 shrink-0" viewBox="0 0 24 24" fill="currentColor">
                              <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
                            </svg>
                            {featured.item.location}
                          </span>
                        )}
                      </div>
                    )}
                    {featured.item.url ? (
                      <a href={featured.item.url} target="_blank" rel="noopener noreferrer"
                        class="text-sm font-bold leading-snug hover:text-primary-dark transition-colors">
                        {featured.item.title}
                      </a>
                    ) : (
                      <span class="text-sm font-bold leading-snug">{featured.item.title}</span>
                    )}
                    {featured.item.subtitle && (
                      <span class="text-xs text-n400">{featured.item.subtitle}</span>
                    )}
                    {featured.item.lab && (
                      <p class="text-xs text-yellow-400">🔬 {featured.item.lab}</p>
                    )}
                  </div>
                  {featured.item.logo && (
                    <button
                      class="h-7 w-auto shrink-0 bg-white rounded p-0.5 cursor-zoom-in hover:scale-110 transition-transform"
                      data-logo-src={featured.item.logo}
                      onclick="document.getElementById('logo-dialog-img').src=this.dataset.logoSrc; document.getElementById('logo-dialog').showModal()"
                      aria-label="View image full size"
                    >
                      <img src={featured.item.logo} alt="" class="h-full w-auto" />
                    </button>
                  )}
                </div>
                <hr class="border-n700 mb-2" />
              </div>
            )}

            {/* ── Remaining items ── */}
            {rest.subgroups ? (
              rest.subgroups.map((group, i) => (
                <div class={i > 0 ? "mt-3 pt-3 border-t border-n700" : ""}>
                  <p class="text-xs font-semibold uppercase tracking-widest text-teal-400 mb-2">{group.title}</p>
                  <ul class="flex flex-col gap-3">
                    {group.items.map((item) => (
                      <li class="flex items-start gap-2">
                        <div class="flex flex-col gap-0.5 flex-1">
                          {(item.date || item.location) && (
                            <div class="flex flex-wrap items-center gap-2 mb-0.5">
                              {item.date && (
                                <Badge className="bg-primary-dark w-fit rounded-md whitespace-nowrap text-xs">
                                  {item.date}
                                </Badge>
                              )}
                              {item.location && (
                                <span class="flex items-center gap-1 text-xs font-medium text-teal-400">
                                  <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 shrink-0" viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
                                  </svg>
                                  {item.location}
                                </span>
                              )}
                            </div>
                          )}
                          {item.url ? (
                            <a href={item.url} target="_blank" rel="noopener noreferrer"
                              class="text-sm font-bold leading-snug hover:text-primary-dark transition-colors">
                              {item.title}
                            </a>
                          ) : (
                            <span class="text-sm font-bold leading-snug">{item.title}</span>
                          )}
                          {item.subtitle && <span class="text-xs text-n400">{item.subtitle}</span>}
                          {item.lab && <p class="text-xs text-yellow-400">🔬 {item.lab}</p>}
                          {item.description && <p class="text-xs text-n300 leading-relaxed mt-0.5">{item.description}</p>}
                          {item.documentUrl && (
                            <a href={item.documentUrl} target="_blank" rel="noopener noreferrer"
                              class="text-xs text-teal-400 hover:underline underline-offset-2 w-fit mt-0.5">
                              {item.documentLabel ?? "View document"}
                            </a>
                          )}
                        </div>
                        {item.logo && (
                          <button
                            class="h-7 w-auto shrink-0 mt-0.5 bg-white rounded p-0.5 cursor-zoom-in hover:scale-110 transition-transform"
                            data-logo-src={item.logo}
                            onclick="document.getElementById('logo-dialog-img').src=this.dataset.logoSrc; document.getElementById('logo-dialog').showModal()"
                            aria-label="View image full size"
                          >
                            <img src={item.logo} alt="" class="h-full w-auto" />
                          </button>
                        )}
                      </li>
                    ))}
                  </ul>
                </div>
              ))
            ) : (
              <ul class="flex flex-col gap-3">
                {(rest.items ?? []).map((item) => (
                  <li class="flex items-start gap-2">
                    <div class="flex flex-col gap-0.5 flex-1">
                      {(item.date || item.location) && (
                        <div class="flex flex-wrap items-center gap-2 mb-0.5">
                          {item.date && (
                            <Badge className="bg-primary-dark w-fit rounded-md whitespace-nowrap text-xs">
                              {item.date}
                            </Badge>
                          )}
                          {item.location && (
                            <span class="flex items-center gap-1 text-xs font-medium text-teal-400">
                              <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 shrink-0" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
                              </svg>
                              {item.location}
                            </span>
                          )}
                        </div>
                      )}
                      {item.url ? (
                        <a href={item.url} target="_blank" rel="noopener noreferrer"
                          class="text-sm font-bold leading-snug hover:text-primary-dark transition-colors">
                          {item.title}
                        </a>
                      ) : (
                        <span class="text-sm font-bold leading-snug">{item.title}</span>
                      )}
                      {item.subtitle && <span class="text-xs text-n400">{item.subtitle}</span>}
                      {item.lab && <p class="text-xs text-yellow-400">🔬 {item.lab}</p>}
                      {item.description && <p class="text-xs text-n300 leading-relaxed mt-0.5">{item.description}</p>}
                      {item.documentUrl && (
                        <a href={item.documentUrl} target="_blank" rel="noopener noreferrer"
                          class="text-xs text-teal-400 hover:underline underline-offset-2 w-fit mt-0.5">
                          {item.documentLabel ?? "View document"}
                        </a>
                      )}
                    </div>
                    {item.logo && (
                      <button
                        class="h-7 w-auto shrink-0 mt-0.5 bg-white rounded p-0.5 cursor-zoom-in hover:scale-110 transition-transform"
                        data-logo-src={item.logo}
                        onclick="document.getElementById('logo-dialog-img').src=this.dataset.logoSrc; document.getElementById('logo-dialog').showModal()"
                        aria-label="View image full size"
                      >
                        <img src={item.logo} alt="" class="h-full w-auto" />
                      </button>
                    )}
                  </li>
                ))}
              </ul>
            )}
          </div>
        </div>
      </section>
    );
  })}
</div>

{/* Lightbox dialog — shared, src set dynamically on click */}
<dialog id="logo-dialog" onclick="this.close()">
  <img id="logo-dialog-img" src="" alt="" />
</dialog>

<style>
  .communication-scroll {
    scrollbar-width: thin;
    scrollbar-color: #4b5563 transparent;
  }
  .communication-scroll::-webkit-scrollbar { width: 4px; }
  .communication-scroll::-webkit-scrollbar-track { background: transparent; }
  .communication-scroll::-webkit-scrollbar-thumb {
    background-color: #4b5563;
    border-radius: 9999px;
  }
  #logo-dialog::backdrop { background: rgba(0, 0, 0, 0.75); }
  #logo-dialog {
    background: white;
    border: none;
    border-radius: 0.75rem;
    padding: 1.5rem;
    max-width: 90vw;
    max-height: 90vh;
  }
  #logo-dialog img {
    max-width: 100%;
    max-height: 80vh;
    display: block;
  }
</style>
