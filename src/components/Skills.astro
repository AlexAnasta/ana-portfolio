---
import type { Locale } from "@/i18n";
import { useTranslations } from "@/i18n";
import { getLocalizedContent } from "@/i18n/content";
import CustomSkillCard from "./CustomSkillCard";
import LanguageCard from "./LanguageCard.astro";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const { skillCategories, languages } = getLocalizedContent(locale);
---

<div class="relative flex flex-col gap-8 text-n700 dark:text-n200 w-full mt-10 px-4">
  {skillCategories.map((category) => (
    <div class="mb-4">
      <h2 class="text-3xl font-bold mb-4 text-center text-primary-dark">{category.title}</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {category.skills.map((skill) => (
          <CustomSkillCard
            name={skill.name}
            description={skill.description}
            iconKey={skill.icon}
            badges={skill.badges}
          />
        ))}
      </div>
    </div>
  ))}

  {/* Languages */}
  <div class="mb-4">
    <h2 class="text-2xl font-bold mb-4 text-center text-primary-dark">{t("home.skills.languages")}</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      {languages.filter((l) => l.show).map((lang) => (
        <LanguageCard name={lang.name} level={lang.level} description={lang.description} />
      ))}
    </div>
  </div>
</div>