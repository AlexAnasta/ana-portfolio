---
import RussianIcon from "./icons/RussianIcon";
import FrenchIcon from "./icons/FrenchIcon";
import EnglishIcon from "./icons/EnglishIcon";

interface Props {
	name: string;
	level: string;
	description: string;
}

const { name, level, description } = Astro.props;

const icons: Record<string, any> = {
	Russian: RussianIcon,
	Russe: RussianIcon,
	French: FrenchIcon,
	Français: FrenchIcon,
	English: EnglishIcon,
	Anglais: EnglishIcon,
};

const Icon = icons[name];
---

<div class="flex flex-col gap-2 bg-n700 p-4 rounded-md">
	{Icon && (
		<div class="w-10 h-10" style="color: #FAE081;">
			<Icon width={40} height={40} fill="currentColor" />
		</div>
	)}
	<h3 class="text-lg font-bold">{name}</h3>
	<span class="text-xs font-semibold text-teal-400 uppercase tracking-wide whitespace-pre-line">{level}</span>
	<p class=" text-n200 text-sm">{description}</p>
</div>