---
import type { Locale } from "@/i18n";
import { useTranslations } from "@/i18n";

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

---

<footer class="container py-4 text-center">
	<p>
		{t("footer.madeWith")} ❤️ by <a
			href="https://github.com/aerusakovich"
			target="_blank"
			rel="noopener noreferrer">Ana</a
		> & <a
			href="https://github.com/Alexis-Pannetier"
			target="_blank"
			rel="noopener noreferrer">Alex</a
		>.
	</p>
</footer>
