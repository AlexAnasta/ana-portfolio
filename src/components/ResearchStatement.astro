---
import type { Locale } from "@/i18n";
import { useTranslations } from "@/i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

type Tone = "wet" | "dry";
type Segment = { text: string; tone?: Tone };

const TOKEN_REGEX = /\[\[(wet|dry):([\s\S]*?)\]\]/g;

const parseToneText = (text: string): Segment[] => {
  const segments: Segment[] = [];
  let lastIndex = 0;

  for (const match of text.matchAll(TOKEN_REGEX)) {
    const full = match[0];
    const tone = match[1] as Tone;
    const value = match[2] ?? "";
    const start = match.index ?? 0;

    if (start > lastIndex) {
      segments.push({ text: text.slice(lastIndex, start) });
    }

    segments.push({ text: value, tone });
    lastIndex = start + full.length;
  }

  if (lastIndex < text.length) {
    segments.push({ text: text.slice(lastIndex) });
  }

  return segments;
};

const researchP1 = parseToneText(t("home.research.p1"));
const researchP2 = parseToneText(t("home.research.p2"));
const researchP3 = parseToneText(t("home.research.p3"));
---

<div class="research-statement w-full my-4 px-4 py-3 rounded-xl border border-primary-light/30 dark:border-primary-dark/30 bg-n100/60 dark:bg-n800/60 backdrop-blur-sm">
  <p class="text-sm md:text-base text-n700 dark:text-n200 leading-relaxed mb-3">
    {researchP1.map((segment) => (segment.tone ? <span class={segment.tone}>{segment.text}</span> : segment.text))}
  </p>
  <p class="text-sm md:text-base text-n700 dark:text-n200 leading-relaxed mb-3">
    {researchP2.map((segment) => (segment.tone ? <span class={segment.tone}>{segment.text}</span> : segment.text))}
  </p>
  <p class="text-sm md:text-base text-n700 dark:text-n200 leading-relaxed">
    {researchP3.map((segment) => (segment.tone ? <span class={segment.tone}>{segment.text}</span> : segment.text))}
  </p>
</div>

<style>
  .wet {
    color: #62C4C3;
    font-weight: 600;
  }
  .dry {
    color: #FAE081;
    font-weight: 600;
  }
</style>